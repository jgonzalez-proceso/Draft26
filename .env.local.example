# Supabase — copia este archivo a .env.local y rellena con los valores de tu proyecto
# (Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# URL pública del sitio (para enlaces de invitación). En local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API-Football (api-sports.io) — clave SOLO servidor (sin prefijo NEXT_PUBLIC_)
API_FOOTBALL_KEY=tu-clave-api-football
API_FOOTBALL_LEAGUE=1
# Edición del Mundial. 2026 requiere plan de pago; el plan Free solo da 2022-2024.

# WC 2026 — fuentes de datos (no necesitan clave)
WC_ESPN_ENABLED=true
# Poner a true cuando el workflow N8N esté activo y escribiendo en Supabase
WC_N8N_DB_ENABLED=false
